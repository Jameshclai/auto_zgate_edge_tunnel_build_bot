# Copy to .env and fill in. Do not commit .env.
# Telegram Bot API token (from BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# Optional: sudo password for non-interactive build (test machine only)
# SUDO_PASS=

# Optional: override builder paths (default: sibling dirs of this project)
# SDK_BUILDER_ROOT=/home/user/zgate-sdk-c-builder
# TUNNEL_BUILDER_ROOT=/home/user/zgate-tunnel-sdk-c-builder

# Optional: vcpkg and output paths (passed to builders)
# VCPKG_ROOT=/home/user/vcpkg
# ZGATE_SDK_BUILDER_OUTPUT=/home/user/zgate-sdk-c-builder/output
